{
  "name": "fin-fisheries-inspection-navigator",
  "version": "1.0.0",
  "private": true,
  "description": "FIN - Fisheries Inspection Navigator (Northeast)",
  "scripts": {
    "validate": "node scripts/validate-species-data.js && node scripts/validate-violation-coverage.js && node scripts/validate-species-schema.js",
    "validate:species": "node scripts/validate-species-data.js",
    "validate:violations": "node scripts/validate-violation-coverage.js",
    "validate:schema": "node scripts/validate-species-schema.js",
    "test:smoke": "node scripts/smoke-scenarios.js",
    "test:e2e": "playwright test",
    "pages:check": "node scripts/check-pages-sync.js",
    "release:check": "npm test && npm run pages:check",
    "test": "npm run validate && npm run test:smoke"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  }
}
